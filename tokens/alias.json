  "spacing": {
    "$type": "dimension",
    "$description": "Semantic spacing aliases. Maps scale primitives to human-readable sizes. Tier 2 of the design system.",
    "spacing": {
      "none": {
        "$value": "{spacing.scale.0}",
        "$description": "No spacing."
      },
      "xxs": {
        "$value": "{spacing.scale.1}",
        "$description": "2px - hairline gap, focus ring offset."
      },
      "xs": {
        "$value": "{spacing.scale.2}",
        "$description": "4px - tight inline spacing."
      },
      "sm": {
        "$value": "{spacing.scale.3}",
        "$description": "8px - compact padding, small gaps."
      },
      "md": {
        "$value": "{spacing.scale.5}",
        "$description": "16px - default padding and gap."
      },
      "lg": {
        "$value": "{spacing.scale.7}",
        "$description": "24px - roomy padding, section gaps."
      },
      "xl": {
        "$value": "{spacing.scale.8}",
        "$description": "32px - large gaps, grid gutters."
      },
      "2xl": {
        "$value": "{spacing.scale.9}",
        "$description": "40px - generous section spacing."
      },
      "3xl": {
        "$value": "{spacing.scale.10}",
        "$description": "48px - minimum touch target, large containers."
      },
      "4xl": {
        "$value": "{spacing.scale.12}",
        "$description": "64px - layout insets."
      },
      "5xl": {
        "$value": "{spacing.scale.14}",
        "$description": "96px - page margins, hero spacing."
      }
    }
  },
  "typography": {
    "$type": "typography",
    "$description": "Semantic type scale aliases. Composes primitive typography tokens into named scales. Tier 2 of the design system.",
    "typeFamily": {
      "sans": {
        "$value": "{typography.fontFamily.sans}",
        "$description": "Alias for Inter — use for all UI text."
      },
      "mono": {
        "$value": "{typography.fontFamily.mono}",
        "$description": "Alias for Geist Mono — use for code and numeric data."
      }
    },
    "typeScale": {
      "xs": {
        "fontSize": "{typography.fontSize.12}",
        "lineHeight": "{typography.lineHeight.normal}",
        "fontWeight": "{typography.fontWeight.regular}",
        "letterSpacing": "{typography.letterSpacing.wide}",
        "$description": "12px — captions, timestamps, meta."
      },
      "sm": {
        "fontSize": "{typography.fontSize.14}",
        "lineHeight": "{typography.lineHeight.normal}",
        "fontWeight": "{typography.fontWeight.regular}",
        "letterSpacing": "{typography.letterSpacing.normal}",
        "$description": "14px — secondary text, labels, helper text."
      },
      "md": {
        "fontSize": "{typography.fontSize.16}",
        "lineHeight": "{typography.lineHeight.normal}",
        "fontWeight": "{typography.fontWeight.regular}",
        "letterSpacing": "{typography.letterSpacing.normal}",
        "$description": "16px — default body text."
      },
      "lg": {
        "fontSize": "{typography.fontSize.18}",
        "lineHeight": "{typography.lineHeight.snug}",
        "fontWeight": "{typography.fontWeight.regular}",
        "letterSpacing": "{typography.letterSpacing.normal}",
        "$description": "18px — large body, intro text."
      },
      "xl": {
        "fontSize": "{typography.fontSize.20}",
        "lineHeight": "{typography.lineHeight.snug}",
        "fontWeight": "{typography.fontWeight.medium}",
        "letterSpacing": "{typography.letterSpacing.tight}",
        "$description": "20px — small headings, h4."
      },
      "2xl": {
        "fontSize": "{typography.fontSize.24}",
        "lineHeight": "{typography.lineHeight.tight}",
        "fontWeight": "{typography.fontWeight.semibold}",
        "letterSpacing": "{typography.letterSpacing.tight}",
        "$description": "24px — card headers, h3."
      },
      "3xl": {
        "fontSize": "{typography.fontSize.32}",
        "lineHeight": "{typography.lineHeight.tight}",
        "fontWeight": "{typography.fontWeight.semibold}",
        "letterSpacing": "{typography.letterSpacing.tight}",
        "$description": "32px — section headers, h2."
      },
      "4xl": {
        "fontSize": "{typography.fontSize.36}",
        "lineHeight": "{typography.lineHeight.tight}",
        "fontWeight": "{typography.fontWeight.bold}",
        "letterSpacing": "{typography.letterSpacing.tight}",
        "$description": "36px — page titles, h1."
      },
      "5xl": {
        "fontSize": "{typography.fontSize.48}",
        "lineHeight": "{typography.lineHeight.none}",
        "fontWeight": "{typography.fontWeight.bold}",
        "letterSpacing": "{typography.letterSpacing.tight}",
        "$description": "48px — hero/display headlines."
      }
    }
