{
  "$type": "typography",
  "$description": "Primitive typography tokens — raw values with no semantic meaning. Tier 1 of the design system.",

  "fontFamily": {
    "sans": { "$value": "'Inter', sans-serif",       "$description": "Primary UI font. Used for all text unless overridden." },
    "mono": { "$value": "'Geist Mono', monospace",   "$description": "Monospace font. Used for code, IDs, account numbers, and numeric data." }
  },

  "fontSize": {
    "10": { "$value": "10px" },
    "12": { "$value": "12px" },
    "14": { "$value": "14px" },
    "16": { "$value": "16px" },
    "18": { "$value": "18px" },
    "20": { "$value": "20px" },
    "24": { "$value": "24px" },
    "28": { "$value": "28px" },
    "32": { "$value": "32px" },
    "36": { "$value": "36px" },
    "48": { "$value": "48px" }
  },

  "fontWeight": {
    "regular":  { "$value": "400", "$description": "Default body weight." },
    "medium":   { "$value": "500", "$description": "Slightly emphasised text." },
    "semibold": { "$value": "600", "$description": "Subheadings, labels, UI emphasis." },
    "bold":     { "$value": "700", "$description": "Headings, strong emphasis." }
  },

  "lineHeight": {
    "none":    { "$value": "1",     "$description": "Display/hero text, no extra spacing." },
    "tight":   { "$value": "1.25", "$description": "Large headings." },
    "snug":    { "$value": "1.375","$description": "Subheadings and large UI text." },
    "normal":  { "$value": "1.5",  "$description": "Body text default." },
    "relaxed": { "$value": "1.625","$description": "Long-form readable content." }
  },

  "letterSpacing": {
    "tight":  { "$value": "-0.02em", "$description": "Large display headings." },
    "normal": { "$value": "0em",     "$description": "Default — most UI text." },
    "wide":   { "$value": "0.025em", "$description": "Slightly open — captions, small text." },
    "wider":  { "$value": "0.05em",  "$description": "Overlines and uppercase labels." },
    "widest": { "$value": "0.1em",   "$description": "All-caps decorative text." }
  }
}
