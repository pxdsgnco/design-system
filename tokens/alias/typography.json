{
  "$type": "typography",
  "$description": "Semantic type scale aliases. Composes primitive typography tokens into named scales. Tier 2 of the design system.",

  "typeFamily": {
    "sans": { "$value": "{fontFamily.sans}", "$description": "Alias for Inter — use for all UI text." },
    "mono": { "$value": "{fontFamily.mono}", "$description": "Alias for Geist Mono — use for code and numeric data." }
  },

  "typeScale": {
    "xs": {
      "fontSize":      "{fontSize.12}",
      "lineHeight":    "{lineHeight.normal}",
      "fontWeight":    "{fontWeight.regular}",
      "letterSpacing": "{letterSpacing.wide}",
      "$description":  "12px — captions, timestamps, meta."
    },
    "sm": {
      "fontSize":      "{fontSize.14}",
      "lineHeight":    "{lineHeight.normal}",
      "fontWeight":    "{fontWeight.regular}",
      "letterSpacing": "{letterSpacing.normal}",
      "$description":  "14px — secondary text, labels, helper text."
    },
    "md": {
      "fontSize":      "{fontSize.16}",
      "lineHeight":    "{lineHeight.normal}",
      "fontWeight":    "{fontWeight.regular}",
      "letterSpacing": "{letterSpacing.normal}",
      "$description":  "16px — default body text."
    },
    "lg": {
      "fontSize":      "{fontSize.18}",
      "lineHeight":    "{lineHeight.snug}",
      "fontWeight":    "{fontWeight.regular}",
      "letterSpacing": "{letterSpacing.normal}",
      "$description":  "18px — large body, intro text."
    },
    "xl": {
      "fontSize":      "{fontSize.20}",
      "lineHeight":    "{lineHeight.snug}",
      "fontWeight":    "{fontWeight.medium}",
      "letterSpacing": "{letterSpacing.tight}",
      "$description":  "20px — small headings, h4."
    },
    "2xl": {
      "fontSize":      "{fontSize.24}",
      "lineHeight":    "{lineHeight.tight}",
      "fontWeight":    "{fontWeight.semibold}",
      "letterSpacing": "{letterSpacing.tight}",
      "$description":  "24px — card headers, h3."
    },
    "3xl": {
      "fontSize":      "{fontSize.32}",
      "lineHeight":    "{lineHeight.tight}",
      "fontWeight":    "{fontWeight.semibold}",
      "letterSpacing": "{letterSpacing.tight}",
      "$description":  "32px — section headers, h2."
    },
    "4xl": {
      "fontSize":      "{fontSize.36}",
      "lineHeight":    "{lineHeight.tight}",
      "fontWeight":    "{fontWeight.bold}",
      "letterSpacing": "{letterSpacing.tight}",
      "$description":  "36px — page titles, h1."
    },
    "5xl": {
      "fontSize":      "{fontSize.48}",
      "lineHeight":    "{lineHeight.none}",
      "fontWeight":    "{fontWeight.bold}",
      "letterSpacing": "{letterSpacing.tight}",
      "$description":  "48px — hero/display headlines."
    }
  }
}
